# =============================================================================
# Lead Monitor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to GitHub (it's in .gitignore)

# Reddit API credentials
# Get these at: https://www.reddit.com/prefs/apps (create a "script" type app)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=LeadMonitor/1.0 by AdvanceAIServices

# Anthropic API Key (for Claude Haiku classification)
# Get this at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot (for instant alerts)
# Create a bot: open Telegram, search @BotFather, send /newbot
# Get your chat_id: after creating bot, message it, then visit
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
