# =============================================================================
# Lead Monitor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to GitHub (it's in .gitignore)

# Reddit - NO API KEY NEEDED
# Reddit is accessed via public JSON endpoints, no credentials required.

# Anthropic API Key (for Claude Haiku classification)
# Get this at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot (for instant alerts)
# 1. Open Telegram, search @BotFather, send /newbot
# 2. Follow prompts - you'll get a token like: 123456789:ABCdef...
# 3. Start a chat with your new bot (send it any message)
# 4. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 5. Find "chat":{"id":XXXXXXXXX} - that number is your CHAT_ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
