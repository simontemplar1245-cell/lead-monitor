# =============================================================================
# Lead Monitor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to GitHub (it's in .gitignore)

# Reddit - NO API KEY NEEDED
# Reddit is accessed via public JSON endpoints, no credentials required.

# Anthropic API Key (for Claude Haiku classification)
# Get this at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ntfy.sh Push Notifications (for instant alerts)
# 1. Install the "ntfy" app on your phone (iOS App Store / Google Play)
# 2. Open the app, tap "+", subscribe to a topic name (e.g. advance-ai-leads)
# 3. Put that SAME topic name here:
NTFY_TOPIC=advance-ai-leads
# Optional: self-hosted ntfy server (default: https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
